# ========== GitHub（拉取 PR diff）==========
# 在 https://github.com/settings/tokens 创建 Personal Access Token
# 公开仓库：勾选 public_repo 即可；私有仓库：勾选 repo
GITHUB_TOKEN=

# ========== 大模型（OpenAI 兼容接口）==========

# --- 方案 A：通义千问 DashScope（推荐国内）---
OPENAI_API_KEY=你的千问_API_Key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# --- 方案 B：OpenAI 官方 ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- 方案 C：DeepSeek ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# Optional limits
MAX_FILES_IN_CONTEXT=30
MAX_PATCH_CHARS_PER_FILE=8000
MAX_TOTAL_CONTEXT_CHARS=120000

# RULES_PATH=rules/default.md
