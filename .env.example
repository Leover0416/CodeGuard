# GitHub Personal Access Token (repo scope recommended for private repos)
GITHUB_TOKEN=

# OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional limits
MAX_FILES_IN_CONTEXT=30
MAX_PATCH_CHARS_PER_FILE=8000
MAX_TOTAL_CONTEXT_CHARS=120000
